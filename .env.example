# ============================================================================
# SUPABASE ENVIRONMENT VARIABLES EXAMPLE
# Copy this file to .env.local and fill in your actual values
# ============================================================================

# Supabase Project URL
# Get this from: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key (Public Key)
# Get this from: Supabase Dashboard > Settings > API > anon public
# Use this for client-side operations
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (Private Key)
# Get this from: Supabase Dashboard > Settings > API > service_role
# ⚠️ NEVER expose this in frontend! Use only in backend/server
# Store this in .env.local (add to .gitignore)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================================
# OPTIONAL: Additional Configuration
# ============================================================================

# Database
NEXT_PUBLIC_DATABASE_URL=postgresql://postgres:password@localhost:5432/barbershop_saas

# API Keys for Third-party Services (if needed)
# WHATSAPP_API_KEY=your-whatsapp-api-key
# PIX_API_KEY=your-pix-api-key
# STRIPE_SECRET_KEY=your-stripe-key

# ============================================================================
# NOTES:
# ============================================================================
# 1. Add .env.local to .gitignore - NEVER commit secrets!
# 2. NEXT_PUBLIC_* variables are exposed to the browser
# 3. Other variables are server-only
# 4. Update these after creating your Supabase project
# 5. For production, use environment variables from your hosting platform
